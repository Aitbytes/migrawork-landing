---
interface Props { appName: string; }
const { appName } = Astro.props;
---
<footer class="bg-primary text-white/80 py-12 px-4">
  <div class="max-w-6xl mx-auto">
    <div class="grid sm:grid-cols-3 gap-8 sm:gap-12 mb-10">
      <!-- Logo + tagline -->
      <div class="sm:col-span-1">
        <a href="/" class="flex items-center gap-2.5 mb-4">
          <div class="w-9 h-9 rounded-lg bg-white/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 12l2 2 4-4"/>
              <path d="M12 3a9 9 0 1 0 9 9"/>
            </svg>
          </div>
          <span class="font-heading text-xl font-semibold text-white">MigraWork</span>
        </a>
        <p class="text-sm text-white/60 leading-relaxed">Workplace accommodation templates built specifically for headache disorder sufferers.</p>
      </div>

      <!-- Quick links -->
      <div>
        <h4 class="font-semibold text-white mb-4 text-sm">Product</h4>
        <ul class="space-y-2.5">
          <li><a href="#how-it-works" class="text-sm text-white/60 hover:text-white transition-colors">How It Works</a></li>
          <li><a href="#features" class="text-sm text-white/60 hover:text-white transition-colors">Features</a></li>
          <li><a href="#faq" class="text-sm text-white/60 hover:text-white transition-colors">FAQ</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="font-semibold text-white mb-4 text-sm">Legal</h4>
        <ul class="space-y-2.5">
          <li><a href="#" class="text-sm text-white/60 hover:text-white transition-colors">Privacy Policy</a></li>
          <li><a href="#" class="text-sm text-white/60 hover:text-white transition-colors">Terms of Service</a></li>
          <li><a href="#" class="text-sm text-white/60 hover:text-white transition-colors">ADA Disclaimer</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="pt-8 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-white/40">© 2026 MigraWork. All rights reserved.</p>
      <p class="text-xs text-white/40">Built for headache disorder sufferers, by people who understand.</p>
    </div>
  </div>
</footer>
